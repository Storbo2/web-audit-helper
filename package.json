{
    "name": "web-audit-helper",
    "version": "1.3.2",
    "type": "module",
    "description": "Framework-agnostic web audit overlay for accessibility, SEO, semantic and responsive validation.",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "license": "MIT",
    "author": "Storbo",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Storbo2/web-audit-helper.git"
    },
    "homepage": "https://github.com/Storbo2/web-audit-helper#readme",
    "bugs": {
        "url": "https://github.com/Storbo2/web-audit-helper/issues"
    },
    "keywords": [
        "accessibility",
        "audit",
        "a11y",
        "seo",
        "semantic-html",
        "web-audit",
        "overlay",
        "wcag",
        "lighthouse",
        "developer-tools",
        "quality-assurance",
        "responsive",
        "performance"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/node": "^25.3.0",
        "@vitest/coverage-v8": "^4.0.18",
        "@vitest/ui": "^4.0.18",
        "http-server": "^14.1.1",
        "jsdom": "^25.0.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "prebuild": "node scripts/gen-wah-css.mjs",
        "build": "tsup --config tsup.config.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:debug": "playwright test --debug",
        "test:coverage": "vitest run --coverage",
        "test:all": "npm run test && npm run test:e2e"
    }
}
