{
    "compilerOptions": {
        "target": "ES2019",
        "module": "ESNext",
        "declaration": true,
        "outDir": "dist",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": [
            "vitest/globals",
            "node"
        ]
    },
    "include": [
        "src"
    ]
}